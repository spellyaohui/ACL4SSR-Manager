generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id                String          @id @default(cuid())
  name              String
  description       String?
  token             String          @unique
  defaultTarget     String          @default("clash")
  upstreamConfigUrl String
  nodeExcludeRegex  String?
  subscriptionInfoSourceId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  sources           ProfileSource[]
  rules             Rule[]
}

model ProfileSource {
  id            String     @id @default(cuid())
  profileId     String
  profile       Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type          SourceType
  name          String
  value         String
  tag           String?
  enabled       Boolean    @default(true)
  sortOrder     Int        @default(0)
  lastStatus    String?
  lastCheckedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Rule {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category    String   @default("General")
  type        RuleType
  value       String
  policyGroup String
  mode        RuleMode @default(PIN)
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId, enabled, priority])
}

model UpstreamCache {
  id        String   @id @default(cuid())
  url       String   @unique
  content   String
  status    Int      @default(200)
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  detail    String?
  createdAt DateTime @default(now())
}

enum SourceType {
  SUBSCRIPTION
  NODE
  BULK
}

enum RuleType {
  DOMAIN
  DOMAIN_SUFFIX
  DOMAIN_KEYWORD
  IP_CIDR
  IP_CIDR6
  PROCESS_NAME
  GEOIP
  FINAL
  MATCH
}

enum RuleMode {
  PIN
  FILTER
  DIAGNOSE
}
